pragma solidity ^0.8.20;

import "forge-std/Test.sol";
import "../src/PLATE.sol";

// ============================================================
// MOCKS
// ============================================================

contract MockCbETH {
    mapping(address => uint256) public balanceOf;

    function mint(address to, uint256 amt) external {
        balanceOf[to] += amt;
    }

    function burn(address from, uint256 amt) external {
        balanceOf[from] -= amt;
    }
}

contract MockRouter {
    uint256 public nextAmountOut;
    bool public shouldRevert;

    function setAmountOut(uint256 amt) external {
        nextAmountOut = amt;
    }

    function setRevert(bool r) external {
        shouldRevert = r;
    }

    receive() external payable {}

    function swapExactTokensForETH(
        uint256,
        uint256 minOut,
        address[] calldata,
        address to,
        uint256
    ) external returns (uint256[] memory amounts) {
        require(!shouldRevert, "Router: Call failed");
        require(nextAmountOut >= minOut, "Slippage: Insufficient output");

        payable(to).transfer(nextAmountOut);

        amounts = new uint256;
        amounts[1] = nextAmountOut;
    }
}

// ============================================================
// FINAL FORM TEST SUITE
// ============================================================

contract PlateFinalTest is Test {
    PLATE plate;
    MockCbETH cbETH;
    MockRouter router;

    address OWNER = address(0xABCD);
    address TREASURY = address(0xBEEF);

    address[] users;

    uint256 internal totalDeposited;

    event PrincipalReset(uint256 oldValue, uint256 newValue);

    // ============================================================
    // SETUP
    // ============================================================

    function setUp() public {
        cbETH = new MockCbETH();
        router = new MockRouter();

        vm.deal(address(router), 100 ether);

        plate = new PLATE(
            address(router),
            address(cbETH),
            OWNER,
            TREASURY,
            1 ether
        );

        users.push(address(1));
        users.push(address(2));
        users.push(address(3));
    }

    // ============================================================
    // 🧪 UNIT + EDGE TESTS
    // ============================================================

    function test_SwapTooEarlyReverts() public {
        _seedFees();
        vm.expectRevert();
        plate.swapFeesToETH();
    }

    function test_RouterZeroOutput() public {
        router.setAmountOut(0);

        _seedFees();
        vm.warp(block.timestamp + 25 hours);

        vm.expectRevert();
        plate.swapFeesToETH();
    }

    function test_RouterRevert() public {
        router.setRevert(true);

        _seedFees();
        vm.warp(block.timestamp + 25 hours);

        vm.expectRevert("Router: Call failed");
        plate.swapFeesToETH();
    }

    function test_Event_PrincipalReset() public {
        vm.deal(address(plate), 5 ether);
        plate.routeETH();

        uint256 oldVal = plate.cbETHPrincipal();

        vm.expectEmit(true, true, false, true);
        emit PrincipalReset(oldVal, cbETH.balanceOf(address(plate)));

        plate.resetCbETHPrincipal();
    }

    // ============================================================
    // 🎯 FUZZ TESTS
    // ============================================================

    function testFuzz_Slippage(uint256 output) public {
        output = bound(output, 0.5 ether, 2 ether);

        router.setAmountOut(output);

        _seedFees();
        vm.warp(block.timestamp + 25 hours);

        plate.swapFeesToETH();
    }

    // ============================================================
    // ⚔️ ATTACK SIMULATIONS
    // ============================================================

    function test_Attack_SlashThenReset() public {
        vm.deal(address(plate), 10 ether);
        plate.routeETH();

        uint256 principal = plate.cbETHPrincipal();

        cbETH.burn(address(plate), principal / 2);

        vm.expectRevert();
        plate.harvestYield();

        vm.prank(OWNER);
        plate.resetCbETHPrincipal();
    }

    // ============================================================
    // 🔁 STATEFUL CHAOS
    // ============================================================

    function test_Chaos_RandomizedActions(uint256 amt, uint8 action) public {
        address user = users[block.number % users.length];
        amt = bound(amt, 1e16, 5 ether);

        if (action % 4 == 0) {
            deal(address(plate), user, amt);
            vm.prank(user);
            plate.transfer(address(1), amt);
        } else if (action % 4 == 1) {
            vm.deal(address(plate), amt);
            totalDeposited += amt;
            try plate.routeETH() {} catch {}
        } else if (action % 4 == 2) {
            try plate.resetCbETHPrincipal() {} catch {}
        } else {
            try plate.swapFeesToETH() {} catch {}
        }
    }

    // ============================================================
    // 🔒 INVARIANTS (CRITICAL)
    // ============================================================

    function invariant_PrincipalNeverExceedsBalance() public {
        assertLe(
            plate.cbETHPrincipal(),
            cbETH.balanceOf(address(plate))
        );
    }

    function invariant_NoNegativeFees() public {
        assertGe(plate.balanceOf(address(plate)), 0);
    }

    function invariant_SystemAlwaysLive() public {
        deal(address(plate), address(this), 1 ether);
        plate.transfer(address(1), 1 ether);
    }

    function invariant_NoStuckETH() public {
        if (address(plate).balance > 0) {
            try plate.routeETH() {} catch {}
        }
    }

    function invariant_EconomicSafety() public {
        uint256 totalValue =
            address(plate).balance +
            cbETH.balanceOf(address(plate));

        assertGe(totalValue, 0);
    }

    // ============================================================
    // 🔄 FULL LIFECYCLE
    // ============================================================

    function test_FullLifecycle() public {
        _seedFees();

        vm.warp(block.timestamp + 25 hours);

        plate.swapFeesToETH();
        plate.routeETH();

        cbETH.mint(address(plate), 1 ether);

        plate.harvestYield();

        assertGt(address(plate).balance, 0);
    }

    // ============================================================
    // HELPERS
    // ============================================================

    function _seedFees() internal {
        uint256 amt = plate.minSwapBatch() * 10_000 / 200;

        deal(address(plate), address(this), amt);
        plate.transfer(address(1), amt);
    }

    receive() external payable {}
}
